# .env.example
# Configuración del proveedor de correo para StageKit Core
# Opciones soportadas: placeholder, resend, smtp, ses
EMAIL_PROVIDER=placeholder

# Si usas Resend, SMTP o SES, configura sus respectivas claves aquí:
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
